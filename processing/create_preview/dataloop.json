{
    "name": "create-preview-for-usd",
    "displayName": "Create Preview for USD files",
    "description": "This app creates a preview for USD files, which are used in the data management interface to preview the content of the file.",
    "version": "0.0.1",
    "scope": "public",
    "attributes": {
        "Category": "Application",
        "Provider": "Dataloop",
        "Application Type": "Function",
        "Media Type": ["Image"],
        "License": "Apache 2.0"
    },
    "codebase": {
        "type": "git",
        "gitUrl": "https://github.com/dataloop-ai-apps/preview-dm.git",
        "gitTag": "0.0.1"
    },
    "components": {
        "modules": [
            {
                "name": "generate_preview",
                "entryPoint": "processing/create_preview/service_runner.py",
                "className": "ServiceRunner",
                "functions": [
                    {
                        "name": "generate_preview",
                        "description": "Generate a preview for a USD file",
                        "input": [
                            {
                                "type": "Item",
                                "name": "item"
                            }
                        ],
                        "output": [],
                        "displayName": "Item Quality Scores Calculator"
                    }
                ]
            }
        ],
        "services": [
            {
                "name": "create-preview-for-usd",
                "moduleName": "generate_preview",
                "runtime": {
                    "podType": "regular-m",
                    "concurrency": 10,
                    "runnerImage": "dataloopai/dtlpy-agent:cpu.py3.8.opencv4.7",
                    "autoscaler": {
                        "type": "rabbitmq",
                        "minReplicas": 0,
                        "maxReplicas": 2,
                        "queueLength": 100
                    }
                },
                "executionTimeout": 600
            }
        ],
        "triggers": [
            {
                "name": "create-preview-for-usd-on-item",
                "active": true,
                "type": "Event",
                "namespace": "services.create-preview-for-usd",
                "spec": {
                    "filter": {
                        "$and": [
                            {
                                "$or": [
                                    { "filename": "*.usd" },
                                    { "filename": "*.usda" },
                                    { "filename": "*.usdc" },
                                    { "filename": "*.usdb" },
                                    { "filename": "*.usdz" }
                                ]
                            },
                            {
                                "hidden": false
                            },
                            {
                                "type": "file"
                            }
                        ]
                    },
                    "executionMode": "Always",
                    "resource": "Item",
                    "actions": ["Created"],
                    "input": {},
                    "operation": {
                        "type": "function",
                        "functionName": "generate_preview"
                    }
                }
            }
        ]
    }
}
