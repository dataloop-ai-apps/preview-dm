{
    "name": "generate-mesh-thumbnail",
    "displayName": "Generate Mesh Thumbnail",
    "description": "Generate PNG thumbnails for mesh files using Blender.",
    "version": "0.0.1",
    "scope": "project",
    "attributes": {
        "Category": "Application",
        "Provider": "Dataloop",
        "Application Type": "Function",
        "Media Type": ["Image"],
        "License": "Apache 2.0"
    },
    "components": {
        "modules": [
            {
                "name": "generate_mesh_thumbnail",
                "entryPoint": "processing/generate_thumbnails_mesh/service_runner.py",
                "className": "ServiceRunner",
                "functions": [
                    {
                        "name": "generate_thumbnail",
                        "description": "Generate a PNG thumbnail for a mesh file",
                        "input": [
                            {
                                "type": "Item",
                                "name": "item"
                            }
                        ],
                        "output": [],
                        "displayName": "Generate Mesh Thumbnail"
                    }
                ]
            }
        ],
        "services": [
            {
                "name": "generate-mesh-thumbnail",
                "moduleName": "generate_mesh_thumbnail",
                "runtime": {
                    "podType": "regular-m",
                    "concurrency": 5,
                    "runnerImage": "gcr.io/viewo-g/piper/agent/cpu/preview-processing:0.0.5",
                    "autoscaler": {
                        "type": "rabbitmq",
                        "minReplicas": 1,
                        "maxReplicas": 2,
                        "queueLength": 50
                    }
                },
                "executionTimeout": 900
            }
        ],
        "triggers": [
            {
                "name": "generate-mesh-thumbnail-on-item",
                "active": true,
                "type": "Event",
                "namespace": "services.generate-mesh-thumbnail",
                "spec": {
                    "filter": {
                        "$and": [
                            {
                                "$or": [
                                    { "filename": "*.glb" },
                                    { "filename": "*.gltf" },
                                    { "filename": "*.obj" },
                                    { "filename": "*.stl" },
                                    { "filename": "*.ply" },
                                    { "filename": "*.fbx" },
                                    { "filename": "*.3ds" }
                                ]
                            },
                            { "hidden": false },
                            { "type": "file" }
                        ]
                    },
                    "executionMode": "Always",
                    "resource": "Item",
                    "actions": ["Created"],
                    "input": {},
                    "operation": {
                        "type": "function",
                        "functionName": "generate_thumbnail"
                    }
                }
            }
        ]
    }
}
