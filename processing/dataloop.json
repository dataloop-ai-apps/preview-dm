{
    "name": "preview-processing",
    "displayName": "Preview Processing Service",
    "description": "Unified service for generating previews and thumbnails for various file types (USD, DICOM, Mesh, Office documents).",
    "version": "0.0.15",
    "scope": "public",
    "codebase": {
        "type": "git",
        "gitUrl": "https://github.com/dataloop-ai-apps/preview-dm.git",
        "gitTag": "0.0.15"
    },
    "attributes": {
        "Category": "Application",
        "Provider": "Dataloop",
        "Application Type": "Function",
        "Media Type": ["Image", "Document"],
        "License": "Apache 2.0"
    },
    "components": {
        "modules": [
            {
                "name": "preview_processing",
                "entryPoint": "processing/service_runner.py",
                "className": "ServiceRunner",
                "functions": [
                    {
                        "name": "generate_usd_preview",
                        "description": "Generate a preview for a USD file (converts to GLB and creates PNG thumbnail)",
                        "input": [{ "type": "Item", "name": "item" }],
                        "output": [],
                        "displayName": "Generate USD Preview"
                    },
                    {
                        "name": "generate_dicom_thumbnail",
                        "description": "Generate a PNG thumbnail for a DICOM file",
                        "input": [{ "type": "Item", "name": "item" }],
                        "output": [],
                        "displayName": "Generate DICOM Thumbnail"
                    },
                    {
                        "name": "generate_mesh_thumbnail",
                        "description": "Generate a PNG thumbnail for a mesh file",
                        "input": [{ "type": "Item", "name": "item" }],
                        "output": [],
                        "displayName": "Generate Mesh Thumbnail"
                    },
                    {
                        "name": "convert_office_to_pdf",
                        "description": "Convert an Office document to PDF and set as Preview",
                        "input": [{ "type": "Item", "name": "item" }],
                        "output": [],
                        "displayName": "Office to PDF Preview"
                    }
                ]
            }
        ],
        "services": [
            {
                "name": "preview-processing",
                "moduleName": "preview_processing",
                "runtime": {
                    "podType": "regular-m",
                    "concurrency": 5,
                    "runnerImage": "gcr.io/viewo-g/piper/agent/cpu/preview-processing:0.0.5",
                    "autoscaler": {
                        "type": "rabbitmq",
                        "minReplicas": 1,
                        "maxReplicas": 2,
                        "queueLength": 50
                    }
                },
                "executionTimeout": 900
            }
        ],
        "triggers": [
            {
                "name": "usd-preview-trigger",
                "active": true,
                "type": "Event",
                "namespace": "services.preview-processing",
                "spec": {
                    "filter": {
                        "$and": [
                            {
                                "$or": [
                                    { "filename": "*.usd" },
                                    { "filename": "*.usda" },
                                    { "filename": "*.usdc" },
                                    { "filename": "*.usdb" },
                                    { "filename": "*.usdz" }
                                ]
                            },
                            { "hidden": false },
                            { "type": "file" }
                        ]
                    },
                    "executionMode": "Always",
                    "resource": "Item",
                    "actions": ["Created"],
                    "input": {},
                    "operation": {
                        "type": "function",
                        "functionName": "generate_usd_preview"
                    }
                }
            },
            {
                "name": "dicom-thumbnail-trigger",
                "active": true,
                "type": "Event",
                "namespace": "services.preview-processing",
                "spec": {
                    "filter": {
                        "$and": [
                            {
                                "$or": [
                                    { "filename": "*.dcm" },
                                    { "filename": "*.dicom" }
                                ]
                            },
                            { "hidden": false },
                            { "type": "file" }
                        ]
                    },
                    "executionMode": "Always",
                    "resource": "Item",
                    "actions": ["Created"],
                    "input": {},
                    "operation": {
                        "type": "function",
                        "functionName": "generate_dicom_thumbnail"
                    }
                }
            },
            {
                "name": "mesh-thumbnail-trigger",
                "active": true,
                "type": "Event",
                "namespace": "services.preview-processing",
                "spec": {
                    "filter": {
                        "$and": [
                            {
                                "$or": [
                                    { "filename": "*.glb" },
                                    { "filename": "*.gltf" },
                                    { "filename": "*.obj" },
                                    { "filename": "*.stl" },
                                    { "filename": "*.ply" },
                                    { "filename": "*.fbx" },
                                    { "filename": "*.3ds" }
                                ]
                            },
                            { "hidden": false },
                            { "type": "file" }
                        ]
                    },
                    "executionMode": "Always",
                    "resource": "Item",
                    "actions": ["Created"],
                    "input": {},
                    "operation": {
                        "type": "function",
                        "functionName": "generate_mesh_thumbnail"
                    }
                }
            },
            {
                "name": "office-to-pdf-trigger",
                "active": true,
                "type": "Event",
                "namespace": "services.preview-processing",
                "spec": {
                    "filter": {
                        "$and": [
                            {
                                "$or": [
                                    { "filename": "*.doc" },
                                    { "filename": "*.docx" },
                                    { "filename": "*.rtf" },
                                    { "filename": "*.odt" },
                                    { "filename": "*.xls" },
                                    { "filename": "*.xlsx" },
                                    { "filename": "*.xlsm" },
                                    { "filename": "*.xlsb" },
                                    { "filename": "*.ods" },
                                    { "filename": "*.ppt" },
                                    { "filename": "*.pptx" },
                                    { "filename": "*.odp" }
                                ]
                            },
                            { "hidden": false },
                            { "type": "file" }
                        ]
                    },
                    "executionMode": "Always",
                    "resource": "Item",
                    "actions": ["Created"],
                    "input": {},
                    "operation": {
                        "type": "function",
                        "functionName": "convert_office_to_pdf"
                    }
                }
            }
        ]
    }
}

