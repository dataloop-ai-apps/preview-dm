{
    "version": "0.0.15",
    "name": "preview-dm",
    "displayName": "Preview DM",
    "description": "Preview for Dataloop Data Management",

    "scope": "public",
    "components": {
        "panels": [
            {
                "name": "preview",
                "supportedSlots": [
                    {
                        "type": "itemPreview"
                    }
                ],
                "conditions": {},
                "path": null
            }
        ],
        "toolbars": [
            {
                "displayName": "Preview",
                "name": "preview-toolbar",
                "icon": "",
                "invoke": {
                    "type": "panel",
                    "namespace": "preview"
                },
                "location": "datasetBrowserTab",
                "action": null
            }
        ],
        "modules": [],
        "services": [
            {
                "name": "dataloop-preview-runner",
                "displayName": "Preview Runner",
                "panelNames": ["preview"],
                "initParams": {},
                "runtime": {
                    "podType": "regular-xs",
                    "numReplicas": 1,
                    "concurrency": 10,
                    "runnerImage": "docker.io/dataloopai/dtlpy-agent:cpu.py3.10.opencv",
                    "singleAgent": false,
                    "autoscaler": {
                        "type": "rabbitmq",
                        "minReplicas": 1,
                        "maxReplicas": 1,
                        "queueLength": 1
                    },
                    "preemptible": false,
                    "executionTimeout": 3600
                }
            }
        ]
    },
    "trusted": true
}
